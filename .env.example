# LLM / Gemini
GOOGLE_API_KEY="Your API Key"
GEMINI_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.2


# Embedding
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_DEVICE=cuda
NORMALIZE_EMBEDDINGS=true


# Data paths
PDF_DIR=data/raw/pdf
HTML_DIR=data/raw/html
PROCESSED_DIR=data/processed/multivector_preview
DOWNLOADED_IMAGES_DIR=data/processed/downloaded_images
CHROMA_DIR=storage/chroma


# Chroma
CHROMA_COLLECTION_NAME=uit_admission_multivector
CHROMA_DISTANCE_METRIC=cosine
RESET_INDEX=true
CHROMA_BATCH_SIZE=512


# Ingestion
PROCESS_PDF=true
PROCESS_HTML=true


# Chunking
CHUNK_SIZE=1200
CHUNK_OVERLAP=120


# Retrieval
RETRIEVAL_TOP_K=5
DEBUG_TOP_K=8


# Memory
MEMORY_DIR=storage/memory 
MEMORY_MAX_RECENT_TURNS=4
MEMORY_SUMMARY_TRIGGER_TURNS=8
QUESTION_REWRITE_ENABLED=true


# Reranker
RERANKER_ENABLED=false
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_K=5


# Warm-up
RAG_WARMUP_ENABLED=true